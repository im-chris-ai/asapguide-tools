</style>

<!-- Script Logic -->
<script>
  document.addEventListener('astro:page-load', () => {
    // DOM Selection
    const serverUrlInput = document.getElementById('server-url') as HTMLInputElement;
    if (!serverUrlInput) return; // Safety check for other Astro pages

    const btnConnect = document.getElementById('btn-connect') as HTMLButtonElement;
    const corsAlert = document.getElementById('cors-alert') as HTMLDivElement;
    
    // Model Selection Elements (Searchable Combobox in header)
    const selectContainer = document.getElementById('chat-model-container') as HTMLDivElement;
    const selectSearch = document.getElementById('chat-model-search') as HTMLInputElement;
    const selectArrow = document.getElementById('chat-model-arrow') as HTMLDivElement;
    const selectDropdown = document.getElementById('chat-model-dropdown') as HTMLDivElement;
    const selectOptionsList = document.getElementById('chat-model-options') as HTMLDivElement;
    const hiddenInput = document.getElementById('chat-model-select') as HTMLInputElement;

    const btnUnloadModel = document.getElementById('btn-unload-model') as HTMLButtonElement;
    
    // Chat Workspace Views
    const chatWelcome = document.getElementById('chat-welcome') as HTMLDivElement;

    // Sidebar Parameter Settings
    const sidebarCtxSlider = document.getElementById('sidebar-ctx-slider') as HTMLInputElement;
    const sidebarValCtx = document.getElementById('sidebar-val-ctx') as HTMLElement;
    const sidebarFlash = document.getElementById('sidebar-flash') as HTMLInputElement;

    // Accordion
    const btnToggleParams = document.getElementById('btn-toggle-params') as HTMLButtonElement;
    const paramsContent = document.getElementById('params-content') as HTMLDivElement;
    const paramsArrow = document.getElementById('params-arrow') as SVGElement;
    
    // Config parameters
    const paramSystem = document.getElementById('param-system') as HTMLTextAreaElement;
    const paramTemp = document.getElementById('param-temp') as HTMLInputElement;
    const valTemp = document.getElementById('val-temp') as HTMLSpanElement;
    const paramMaxTokens = document.getElementById('param-max-tokens') as HTMLInputElement;
    const valMaxTokens = document.getElementById('val-max-tokens') as HTMLSpanElement;
    const paramStream = document.getElementById('param-stream') as HTMLInputElement;

    // Chat Interface
    const chatMessages = document.getElementById('chat-messages') as HTMLDivElement;
    const chatInput = document.getElementById('chat-input') as HTMLTextAreaElement;
    const btnSend = document.getElementById('btn-send') as HTMLButtonElement;
    const btnStop = document.getElementById('btn-stop') as HTMLButtonElement;
    const btnClearChat = document.getElementById('btn-clear-chat') as HTMLButtonElement;
    
    // Stats
    const statsBar = document.getElementById('generation-stats-bar') as HTMLDivElement;
    const statTtft = document.getElementById('stat-ttft') as HTMLElement;
    const statSpeed = document.getElementById('stat-speed') as HTMLElement;
    const statCount = document.getElementById('stat-count') as HTMLElement;

    // Diagnostics
    const btnToggleDiagnostics = document.getElementById('btn-toggle-diagnostics') as HTMLButtonElement;
    const diagnosticsContent = document.getElementById('diagnostics-content') as HTMLDivElement;
    const diagnosticsToggleText = document.getElementById('diagnostics-toggle-text') as HTMLSpanElement;
    const logRequest = document.getElementById('log-request') as HTMLElement;
    const logResponse = document.getElementById('log-response') as HTMLElement;
    const btnCopyReqLog = document.getElementById('btn-copy-req-log') as HTMLButtonElement;
    const btnCopyResLog = document.getElementById('btn-copy-res-log') as HTMLButtonElement;

    // Client State Variables
    let isConnected = false;
    let availableModels: any[] = [];
    let activeModelId = ''; // Selected model key from dropdown
    let chatHistory: Array<{role: 'system' | 'user' | 'assistant', content: string}> = [];
    let currentAbortController: AbortController | null = null;
    let isGenerating = false;

    let lastSelectedValue = '';
    let lastSelectedText = '';

    // ── Sliders active display indicators ──
    paramTemp.addEventListener('input', (e) => {
      valTemp.textContent = (e.target as HTMLInputElement).value;
    });

    paramMaxTokens.addEventListener('input', (e) => {
      valMaxTokens.textContent = (e.target as HTMLInputElement).value;
    });

    // Sidebar Context slider listener
    sidebarCtxSlider.addEventListener('input', (e) => {
      sidebarValCtx.textContent = `${(e.target as HTMLInputElement).value} tokens`;
    });

    // ── Toggle Diagnostics ──
    btnToggleDiagnostics.addEventListener('click', () => {
      const isHidden = diagnosticsContent.style.display === 'none';
      diagnosticsContent.style.display = isHidden ? 'block' : 'none';
      diagnosticsToggleText.textContent = isHidden ? 'Hide API Logs' : 'Show API Logs';
    });

    // Copy handlers
    btnCopyReqLog.addEventListener('click', () => {
      navigator.clipboard.writeText(logRequest.textContent || '');
      btnCopyReqLog.textContent = 'Copied!';
      setTimeout(() => { btnCopyReqLog.textContent = 'Copy'; }, 1500);
    });
    btnCopyResLog.addEventListener('click', () => {
      navigator.clipboard.writeText(logResponse.textContent || '');
      btnCopyResLog.textContent = 'Copied!';
      setTimeout(() => { btnCopyResLog.textContent = 'Copy'; }, 1500);
    });

    // Auto-adjust Chat Input Textarea height
    chatInput.addEventListener('input', () => {
      chatInput.style.height = '40px'; // Reset to single line height
      const scrollHeight = chatInput.scrollHeight;
      if (scrollHeight > 40) {
        chatInput.style.height = Math.min(scrollHeight, 160) + 'px';
        chatInput.style.overflowY = scrollHeight > 160 ? 'auto' : 'hidden';
      } else {
        chatInput.style.overflowY = 'hidden';
      }
    });

    // Keybindings: Send on Enter, Shift+Enter for new line
    chatInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        sendMessage();
      }
    });

    // ── Connect & Connect Action ──
    btnConnect.addEventListener('click', () => {
      if (isConnected) {
        disconnectFromServer();
      } else {
        connectToServer();
      }
    });

    function disconnectFromServer() {
      isConnected = false;
      btnConnect.textContent = 'Connect';
      btnConnect.className = 'btn-primary btn-mini-connect';
      serverUrlInput.disabled = false;
      
      disableChatState();
      resetDropdownToDisconnected();
    }

    btnUnloadModel.addEventListener('click', triggerUnload);

    // ── Searchable Combobox Core Logic ──
    function openDropdown() {
      if (!isConnected || selectSearch.disabled) return;
      selectContainer.classList.add('open');
      selectSearch.setAttribute('aria-expanded', 'true');
      selectDropdown.style.display = 'flex';
      selectSearch.value = ''; // clear for searching
      filterOptions('');
    }

    function closeDropdown() {
      selectContainer.classList.remove('open');
      selectSearch.setAttribute('aria-expanded', 'false');
      selectDropdown.style.display = 'none';
      selectSearch.value = lastSelectedText;
      selectSearch.blur();
    }

    selectArrow.addEventListener('click', (e) => {
      e.stopPropagation();
      if (!isConnected || selectSearch.disabled) return;
      if (selectContainer.classList.contains('open')) {
        closeDropdown();
      } else {
        openDropdown();
        selectSearch.focus();
      }
    });

    selectSearch.addEventListener('click', (e) => {
      e.stopPropagation();
      if (!isConnected || selectSearch.disabled) return;
      if (!selectContainer.classList.contains('open')) {
        openDropdown();
      }
    });

    selectSearch.addEventListener('focus', () => {
      if (!isConnected || selectSearch.disabled) return;
      if (!selectContainer.classList.contains('open')) {
        openDropdown();
      }
    });

    selectSearch.addEventListener('input', (e) => {
      if (!selectContainer.classList.contains('open')) {
        selectContainer.classList.add('open');
        selectDropdown.style.display = 'flex';
      }
      filterOptions((e.target as HTMLInputElement).value);
    });

    function filterOptions(query) {
      const filter = query.toLowerCase().trim();
      let matches = 0;

      const existingNoResults = selectOptionsList.querySelector('.custom-select-no-results');
      if (existingNoResults) existingNoResults.remove();

      const options = selectOptionsList.querySelectorAll('.custom-select-option');
      options.forEach(opt => {
        const text = opt.textContent.toLowerCase();
        if (text.includes(filter)) {
          (opt as HTMLElement).style.display = 'block';
          matches++;
        } else {
          (opt as HTMLElement).style.display = 'none';
        }
      });

      if (matches === 0) {
        const noResults = document.createElement('div');
        noResults.className = 'custom-select-no-results';
        noResults.textContent = 'No options found';
        selectOptionsList.appendChild(noResults);
      }
    }

    document.addEventListener('click', (e) => {
      if (!selectContainer.contains(e.target as Node)) {
        if (selectContainer.classList.contains('open')) {
          closeDropdown();
        }
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && selectContainer.classList.contains('open')) {
        closeDropdown();
      }
    });

    async function connectToServer(silent = false) {
      const baseUrl = serverUrlInput.value.trim().replace(/\/+$/, '');
      
      // Reset UI
      btnConnect.textContent = 'Connecting...';
      btnConnect.disabled = true;
      serverUrlInput.disabled = true;
      corsAlert.style.display = 'none';
      selectSearch.disabled = true;

      // Log request in diagnostics
      logRequest.textContent = `GET ${baseUrl}/api/v1/models\nHeaders: {}\nPayload: None`;

      try {
        const response = await fetch(`${baseUrl}/api/v1/models`, {
          method: 'GET',
          mode: 'cors'
        });

        if (!response.ok) {
          throw new Error(`Server returned HTTP ${response.status}`);
        }

        const data = await response.json();
        logResponse.textContent = JSON.stringify(data, null, 2);

        isConnected = true;
        btnConnect.textContent = 'Disconnect';
        btnConnect.className = 'btn-secondary btn-mini-connect';
        btnConnect.disabled = false;
        
        availableModels = data.models || [];
        
        populateModelsDropdown();
        onModelSelectionChange();
        
      } catch (err: any) {
        console.warn('Native endpoint failed, trying OpenAI compatibility endpoint fallback...', err);
        
        // Fallback to OpenAI standard /v1/models endpoint
        try {
          logRequest.textContent += `\n\n[Fallback] GET ${baseUrl}/v1/models`;
          
          const response = await fetch(`${baseUrl}/v1/models`, {
            method: 'GET',
            mode: 'cors'
          });

          if (!response.ok) {
            throw new Error(`OpenAI endpoint returned HTTP ${response.status}`);
          }

          const data = await response.json();
          logResponse.textContent = `[Fallback Response]\n` + JSON.stringify(data, null, 2);

          isConnected = true;
          btnConnect.textContent = 'Disconnect';
          btnConnect.className = 'btn-secondary btn-mini-connect';
          btnConnect.disabled = false;

          // Convert OpenAI models format `{ data: [{ id: "..." }] }` to native-like
          const openAiModels = data.data || [];
          availableModels = openAiModels.map((m: any) => ({
            key: m.id,
            display_name: m.id.split('/').pop() || m.id,
            loaded_instances: [{ id: m.id, config: { context_length: 2048 } }]
          }));

          populateModelsDropdown();
          onModelSelectionChange();

        } catch (fallbackErr: any) {
          console.error('All connection attempts failed:', fallbackErr);
          logResponse.textContent = `Connection Error:\n${fallbackErr.message}\n\nTroubleshooting Hint:\n- Check console logs.\n- Ensure server is active.\n- Verify CORS headers.`;
          
          isConnected = false;
          btnConnect.textContent = 'Connect';
          btnConnect.className = 'btn-primary btn-mini-connect';
          btnConnect.disabled = false;
          serverUrlInput.disabled = false;
          
          if (!silent) {
            corsAlert.style.display = 'block';
            chatWelcome.style.display = 'none';
          }
          
          disableChatState();
          resetDropdownToDisconnected();
        }
      }
    }

    function resetDropdownToDisconnected() {
      selectSearch.value = '';
      selectSearch.placeholder = 'Connect to server first...';
      selectSearch.disabled = true;
      hiddenInput.value = '';
      lastSelectedValue = '';
      lastSelectedText = '';
      selectOptionsList.innerHTML = '';
    }

    function populateModelsDropdown() {
      selectOptionsList.innerHTML = '';
      hiddenInput.value = '';
      lastSelectedValue = '';
      lastSelectedText = '';
      selectSearch.value = '';
      
      if (!availableModels || availableModels.length === 0) {
        selectSearch.placeholder = 'No models downloaded';
        selectSearch.disabled = true;
        return;
      }

      selectSearch.placeholder = 'Select a model...';
      selectSearch.disabled = false;
      
      availableModels.forEach((model) => {
        const opt = document.createElement('div');
        opt.className = 'custom-select-option';
        opt.setAttribute('data-value', model.key);
        opt.setAttribute('role', 'option');
        opt.textContent = model.display_name || model.key;
        
        opt.addEventListener('click', (e) => {
          e.stopPropagation();
          selectOption(model.key, opt.textContent);
        });

        selectOptionsList.appendChild(opt);
      });

      // Auto select first model if available
      if (availableModels.length > 0) {
        const first = availableModels[0];
        selectOption(first.key, first.display_name || first.key);
      }
    }

    function selectOption(value, text) {
      hiddenInput.value = value;
      lastSelectedValue = value;
      lastSelectedText = text;
      selectSearch.value = text;
      
      const options = selectOptionsList.querySelectorAll('.custom-select-option');
      options.forEach(o => {
        if (o.getAttribute('data-value') === value) {
          o.classList.add('selected');
        } else {
          o.classList.remove('selected');
        }
      });
      
      closeDropdown();
      onModelSelectionChange();
    }

    // Handles view changes based on the selected dropdown model's state
    function onModelSelectionChange() {
      const selectedKey = hiddenInput.value;
      if (!selectedKey) {
        disableChatState();
        return;
      }

      const model = availableModels.find(m => m.key === selectedKey);
      if (!model) {
        disableChatState();
        return;
      }

      const isLoaded = model.loaded_instances && model.loaded_instances.length > 0;
      
      if (isLoaded) {
        const loadedInstance = model.loaded_instances[0];
        activeModelId = loadedInstance.id;
        btnUnloadModel.style.display = 'inline-flex';
      } else {
        activeModelId = '';
        btnUnloadModel.style.display = 'none';
      }

      if (isConnected) {
        enableChatState();
      } else {
        disableChatState();
      }
    }

    // Load Model API call (called automatically during sendMessage)
    async function loadModelAuto(baseUrl: string, modelKey: string, contextLength: number, flashAttention: boolean) {
      const payload = {
        model: modelKey,
        context_length: contextLength,
        flash_attention: flashAttention
      };

      logRequest.textContent = `POST ${baseUrl}/api/v1/models/load\nContent-Type: application/json\n\n${JSON.stringify(payload, null, 2)}`;

      const response = await fetch(`${baseUrl}/api/v1/models/load`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(`HTTP ${response.status}: ${errorText || 'Failed to load model'}`);
      }

      const resData = await response.json();
      logResponse.textContent = JSON.stringify(resData, null, 2);
    }

    // Unload active model trigger
    async function triggerUnload() {
      const selectedKey = hiddenInput.value;
      if (!selectedKey) return;

      const model = availableModels.find(m => m.key === selectedKey);
      if (!model || !model.loaded_instances || model.loaded_instances.length === 0) return;

      const instanceId = model.loaded_instances[0].id;
      const baseUrl = serverUrlInput.value.trim().replace(/\/+$/, '');

      // Lock UI
      btnUnloadModel.disabled = true;
      btnUnloadModel.textContent = 'Unloading...';
      selectSearch.disabled = true;
      btnConnect.disabled = true;

      const payload = { instance_id: instanceId };
      logRequest.textContent = `POST ${baseUrl}/api/v1/models/unload\nContent-Type: application/json\n\n${JSON.stringify(payload, null, 2)}`;

      try {
        const response = await fetch(`${baseUrl}/api/v1/models/unload`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          const errorText = await response.text();
          throw new Error(`HTTP ${response.status}: ${errorText || 'Failed to unload model'}`);
        }

        const resData = await response.json();
        logResponse.textContent = JSON.stringify(resData, null, 2);

        // Re-fetch models and restore selection
        await refreshModelsAndSelect(selectedKey);

      } catch (err: any) {
        console.error('Failed to unload model:', err);
        logResponse.textContent = `Failed to unload model:\n${err.message}`;
        alert(`Failed to unload model: ${err.message}`);
        
        // Unlock
        btnUnloadModel.disabled = false;
        btnUnloadModel.textContent = 'Unload';
        selectSearch.disabled = false;
        btnConnect.disabled = false;
      }
    }

    // Help function to reload state and preserve selector key
    async function refreshModelsAndSelect(selectedKey: string) {
      const baseUrl = serverUrlInput.value.trim().replace(/\/+$/, '');
      
      try {
        const response = await fetch(`${baseUrl}/api/v1/models`, { method: 'GET' });
        if (response.ok) {
          const data = await response.json();
          availableModels = data.models || [];
        }
      } catch (err) {
        console.error('Silent refresh failed:', err);
      }

      // Unlock UI
      btnConnect.disabled = false;
      selectSearch.disabled = false;
      btnUnloadModel.disabled = false;
      btnUnloadModel.textContent = 'Unload';

      populateModelsDropdown();
      
      if (selectedKey && Array.from(selectOptionsList.querySelectorAll('.custom-select-option')).some(o => o.getAttribute('data-value') === selectedKey)) {
        const matchingOpt = Array.from(selectOptionsList.querySelectorAll('.custom-select-option')).find(o => o.getAttribute('data-value') === selectedKey);
        selectOption(selectedKey, matchingOpt ? matchingOpt.textContent : selectedKey);
      } else {
        onModelSelectionChange();
      }
    }

    function enableChatState() {
      chatInput.disabled = false;
      btnSend.disabled = false;
      btnClearChat.disabled = false;
      chatInput.placeholder = 'Type a message... (Press Enter to send, Shift+Enter for new line)';
    }

    function disableChatState() {
      activeModelId = '';
      chatInput.disabled = true;
      btnSend.disabled = true;
      btnClearChat.disabled = true;
      chatInput.placeholder = 'Connect to the server to start chat sandbox...';
      btnUnloadModel.style.display = 'none';
      chatWelcome.style.display = 'flex';
      
      // Clean chat history UI
      const chatBubbles = chatMessages.querySelectorAll('.chat-msg');
      chatBubbles.forEach(b => b.remove());
      statsBar.style.display = 'none';
    }

    // ── Clear Chat ──
    btnClearChat.addEventListener('click', () => {
      chatHistory = [];
      const chatBubbles = chatMessages.querySelectorAll('.chat-msg');
      chatBubbles.forEach(b => b.remove());
      statsBar.style.display = 'none';
    });

    // ── Send Message & Streaming completions ──
    btnSend.addEventListener('click', sendMessage);
    btnStop.addEventListener('click', stopGeneration);

    function stopGeneration() {
      if (currentAbortController) {
        currentAbortController.abort();
        isGenerating = false;
        btnSend.style.display = 'inline-flex';
        btnStop.style.display = 'none';
        chatInput.disabled = false;
        
        appendMessage('system', 'Generation stopped by user.');
      }
    }

    async function sendMessage() {
      const prompt = chatInput.value.trim();
      const selectedKey = hiddenInput.value;
      if (!prompt || !selectedKey || isGenerating) return;

      chatWelcome.style.display = 'none';

      // Lock UI
      isGenerating = true;
      btnSend.style.display = 'none';
      btnStop.style.display = 'inline-flex';
      chatInput.disabled = true;
      statsBar.style.display = 'none';

      // Clear input
      chatInput.value = '';
      chatInput.style.height = '40px';

      // Add user message
      appendMessage('user', prompt);
      chatHistory.push({ role: 'user', content: prompt });

      const model = availableModels.find(m => m.key === selectedKey);
      const isLoaded = model && model.loaded_instances && model.loaded_instances.length > 0;
      const baseUrl = serverUrlInput.value.trim().replace(/\/+$/, '');

      try {
        // ── Auto Loading logic on demand ──
        if (!isLoaded) {
          const systemMsgIndex = appendMessage('system', `Loading model "${model?.display_name || selectedKey}" into memory... (This may take a moment depending on your specs)`);
          
          const contextLength = parseInt(sidebarCtxSlider.value) || 2048;
          const flashAttention = sidebarFlash.checked;
          
          await loadModelAuto(baseUrl, selectedKey, contextLength, flashAttention);
          
          // Re-fetch models quietly
          try {
            const refreshRes = await fetch(`${baseUrl}/api/v1/models`, { method: 'GET' });
            if (refreshRes.ok) {
              const refreshData = await refreshRes.json();
              availableModels = refreshData.models || [];
            }
          } catch (e) {
            console.warn('Silent refresh failed during auto load:', e);
          }

          // Update loading message to successful
          const systemMsgEl = chatMessages.querySelectorAll('.chat-msg.system')[systemMsgIndex];
          if (systemMsgEl) {
            systemMsgEl.querySelector('.msg-bubble').textContent = `✓ Model "${model?.display_name || selectedKey}" loaded successfully. Initiating inference...`;
          }

          // Refresh dropdown & dot state
          populateModelsDropdown();
          
          // Re-select option
          const matchingOpt = Array.from(selectOptionsList.querySelectorAll('.custom-select-option')).find(o => o.getAttribute('data-value') === selectedKey);
          selectOption(selectedKey, matchingOpt ? matchingOpt.textContent : selectedKey);
        }

        // Get updated model instance ID
        const updatedModel = availableModels.find(m => m.key === selectedKey);
        const activeInstanceId = updatedModel && updatedModel.loaded_instances && updatedModel.loaded_instances.length > 0 
          ? updatedModel.loaded_instances[0].id 
          : selectedKey;

        // Build completion payload
        const messagesPayload: Array<{role: 'system' | 'user' | 'assistant', content: string}> = [];
        const systemVal = paramSystem.value.trim();
        if (systemVal) {
          messagesPayload.push({ role: 'system', content: systemVal });
        }
        messagesPayload.push(...chatHistory);

        const temp = parseFloat(paramTemp.value);
        const maxTokens = parseInt(paramMaxTokens.value);
        const stream = true; // Always stream

        const completionsUrl = `${baseUrl}/v1/chat/completions`;
        const requestBody = {
          model: activeInstanceId,
          messages: messagesPayload,
          temperature: temp,
          max_tokens: maxTokens,
          stream: stream
        };

        logRequest.textContent = `POST ${completionsUrl}\nContent-Type: application/json\n\n${JSON.stringify(requestBody, null, 2)}`;
        logResponse.textContent = `Sending request...`;

        currentAbortController = new AbortController();

        const assistantMessageIndex = appendMessage('assistant', '');
        const assistantBubbleEl = chatMessages.querySelectorAll('.chat-msg.assistant')[assistantMessageIndex].querySelector('.msg-bubble') as HTMLDivElement;

        let assistantText = '';
        const startTime = performance.now();
        let firstTokenTime: number | null = null;
        let tokenCount = 0;

        const response = await fetch(completionsUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer lm-studio'
          },
          body: JSON.stringify(requestBody),
          signal: currentAbortController.signal
        });

        if (!response.ok) {
          const errorMsg = await response.text();
          throw new Error(`Server returned HTTP ${response.status}: ${errorMsg}`);
        }

        if (!stream) {
          // Non-streaming completions
          const resData = await response.json();
          logResponse.textContent = JSON.stringify(resData, null, 2);

          assistantText = resData.choices[0]?.message?.content || '';
          renderAssistantMarkdown(assistantBubbleEl, assistantText);
          chatHistory.push({ role: 'assistant', content: assistantText });

          const totalDuration = (performance.now() - startTime) / 1000;
          const usage = resData.usage || {};
          const compTokens = usage.completion_tokens || estimateTokens(assistantText);
          const tps = compTokens / totalDuration;
          
          showStats(totalDuration * 1000, tps, compTokens);

        } else {
          // Streaming completions (SSE)
          const reader = response.body?.getReader();
          if (!reader) throw new Error('ReadableStream not supported by browser.');

          const decoder = new TextDecoder('utf-8');
          let buffer = '';
          logResponse.textContent = '';

          while (true) {
            const { done, value } = await reader.read();
            if (done) break;

            buffer += decoder.decode(value, { stream: true });
            const lines = buffer.split('\n');
            buffer = lines.pop() || '';

            for (const line of lines) {
              const cleanLine = line.trim();
              if (!cleanLine) continue;

              logResponse.textContent += cleanLine + '\n';
              logResponse.scrollTop = logResponse.scrollHeight;

              if (cleanLine === 'data: [DONE]') {
                break;
              }

              if (cleanLine.startsWith('data: ')) {
                try {
                  const json = JSON.parse(cleanLine.substring(6));
                  const chunkContent = json.choices[0]?.delta?.content || '';
                  
                  if (chunkContent) {
                    if (firstTokenTime === null) {
                      firstTokenTime = performance.now() - startTime;
                    }

                    tokenCount++;
                    assistantText += chunkContent;
                    
                    assistantBubbleEl.textContent = assistantText;
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                  }
                } catch (jsonErr) {
                  console.debug('JSON parse warning for SSE line:', cleanLine, jsonErr);
                }
              }
            }
          }

          renderAssistantMarkdown(assistantBubbleEl, assistantText);
          chatHistory.push({ role: 'assistant', content: assistantText });

          const totalDuration = (performance.now() - startTime) / 1000;
          const tps = tokenCount / totalDuration;
          showStats(firstTokenTime || 0, tps, tokenCount);
        }

      } catch (err: any) {
        if (err.name === 'AbortError') {
          console.log('User aborted streaming generation.');
        } else {
          console.error('Inference request failed:', err);
          appendMessage('system', `Error: ${err.message}`);
          logResponse.textContent = `Error occurred during request:\n${err.stack || err.message}`;
        }
      } finally {
        isGenerating = false;
        btnSend.style.display = 'inline-flex';
        btnStop.style.display = 'none';
        chatInput.disabled = false;
        currentAbortController = null;
        
        setTimeout(() => chatInput.focus(), 50);
      }
    }

    // Display generation metrics
    function showStats(ttftMs: number, tokensPerSec: number, count: number) {
      statsBar.style.display = 'flex';
      statTtft.textContent = `${Math.round(ttftMs)} ms`;
      statSpeed.textContent = tokensPerSec > 0 ? `${tokensPerSec.toFixed(1)} t/s` : 'N/A';
      statCount.textContent = `${count} tokens`;
    }

    function estimateTokens(text: string): number {
      return Math.round(text.split(/\s+/).length * 1.3);
    }

    function appendMessage(role: 'system' | 'user' | 'assistant', content: string): number {
      const msgWrap = document.createElement('div');
      msgWrap.className = `chat-msg ${role}`;
      
      const badge = document.createElement('span');
      badge.className = 'msg-role-badge';
      badge.textContent = role;
      
      const bubble = document.createElement('div');
      bubble.className = 'msg-bubble';
      bubble.textContent = content;

      if (role !== 'system') {
        msgWrap.appendChild(badge);
      }
      msgWrap.appendChild(bubble);
      
      chatMessages.appendChild(msgWrap);
      chatMessages.scrollTop = chatMessages.scrollHeight;

      return chatMessages.querySelectorAll(`.chat-msg.${role}`).length - 1;
    }

    function renderAssistantMarkdown(containerEl: HTMLDivElement, text: string) {
      if (!text) {
        containerEl.innerHTML = '<span style="color:var(--color-secondary); font-style:italic;">No response content returned.</span>';
        return;
      }

      // Escape HTML
      let html = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

      // Handle Code Blocks
      const codeBlockRegex = /```(\w*)\n([\s\S]*?)```/g;
      html = html.replace(codeBlockRegex, (match, lang, code) => {
        return `<pre><code class="language-${lang}">${code.trim()}</code></pre>`;
      });

      // Handle inline code
      html = html.replace(/`([^`\n]+)`/g, '<code>$1</code>');

      const paragraphs = html.split('\n\n');
      const formatted = paragraphs.map(p => {
        if (p.trim().startsWith('<pre>')) return p;
        return `<p>${p.replace(/\n/g, '<br/>')}</p>`;
      }).join('');

      containerEl.innerHTML = formatted;
    }
    // ── Auto-connect on page load ──
    // Silently attempt connection to the default URL; don't show CORS alert on failure
    connectToServer(true).catch(() => {});
  });
</script>
