---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="LM Studio Server Tester — Connect, Load Models & Chat Locally" 
  description="A client-side developer utility to test connection to your local LM Studio server, load/unload models, configure inference parameters, and chat with streaming tokens."
>
  <!-- ── Full-width Hero ── -->
  <div class="tool-hero">
    <p class="eyebrow">AI Tools</p>
    <h1 class="tool-title">LM Studio <em class="accent">Server</em> Tester</h1>
    <p class="tool-desc">Test your local LM Studio instance, manage model lifecycles, and run streaming chat diagnostics.</p>
  </div>

  <!-- ── Main Workspace ── -->
  <div class="workspace">
    <div class="tester-grid">
      
      <!-- ── Chat Interface (Left - Primary View) ── -->
      <div class="tester-chat-panel">
        
        <!-- Active Model Bar (Chat Header with Server Settings + Model Selector) -->
        <div class="active-model-bar">
          <!-- Left: Server Connection Settings -->
          <div class="header-server-settings">
            <span class="active-label">Server:</span>
            <input type="text" id="server-url" value="http://localhost:1234" placeholder="e.g. http://localhost:1234" class="header-url-input" />
            <button id="btn-connect" class="btn-primary btn-mini-connect">Connect</button>
          </div>

          <!-- Right: Model Selection -->
          <div class="header-model-settings">
            <span class="active-label">Model:</span>
            <div class="model-select-wrapper">
              <div class="custom-select-container" id="chat-model-container">
                <input type="text" id="chat-model-search" class="custom-select-search-input" placeholder="Connect first..." autocomplete="off" role="combobox" aria-expanded="false" aria-haspopup="listbox" disabled />
                <div class="custom-select-arrow" id="chat-model-arrow">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
                <div class="custom-select-dropdown" id="chat-model-dropdown" style="display: none;">
                  <div class="custom-select-options" id="chat-model-options" role="listbox">
                    <!-- Loaded dynamically -->
                  </div>
                </div>
              </div>
              <input type="hidden" id="chat-model-select" value="" />
            </div>
            <button id="btn-unload-model" class="btn-secondary btn-mini-unload" style="display: none;">Unload</button>
          </div>
        </div>

        <!-- Chat Container -->
        <div class="chat-window">
          
          <!-- Message Logs -->
          <div id="chat-messages" class="chat-messages-container">
            
            <!-- Welcome State (No Connection / Instruction) -->
            <div class="chat-welcome-state" id="chat-welcome">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                <path d="m8 7 3 3-3 3"/>
                <line x1="12" y1="13" x2="16" y2="13"/>
              </svg>
              <h2>LM Studio Chat Sandbox</h2>
              <p>Connect to the server in the header to list downloaded models, then select a model and send a message. If the model isn't loaded, it will load automatically.</p>
            </div>

            <!-- CORS Alert Box (Hidden by default, displayed inside viewport on fail) -->
            <div id="cors-alert" class="alert-box error-alert" style="display: none; width: 100%; max-width: 420px; margin: auto;">
              <div class="alert-header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                  <line x1="12" y1="9" x2="12" y2="13"/>
                  <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <strong>Connection Blocked (CORS)</strong>
              </div>
              <p class="alert-desc">Browser blocked connection. Enable CORS in LM Studio.</p>
              <div class="alert-steps">
                <ol>
                  <li>Open <strong>LM Studio</strong> app.</li>
                  <li>Go to the <strong>Developer</strong> tab (<code>&gt;_</code> icon).</li>
                  <li>Under <strong>Server Settings</strong>, toggle <strong>Enable CORS</strong> to <strong>ON</strong>.</li>
                  <li>Verify status shows <span class="badge-inline-green">Running</span>.</li>
                </ol>
              </div>
              <div class="alert-cli-note">
                <span>CLI: <code>lms server start --cors</code></span>
              </div>
            </div>

          </div>

          <!-- Generation Stats (TTFT / Tokens per sec) -->
          <div id="generation-stats-bar" class="generation-stats-row" style="display: none;">
            <div class="stat-pill"><span class="lbl">TTFT:</span> <strong id="stat-ttft">-</strong></div>
            <div class="stat-pill"><span class="lbl">Speed:</span> <strong id="stat-speed">-</strong></div>
            <div class="stat-pill"><span class="lbl">Tokens:</span> <strong id="stat-count">-</strong></div>
          </div>

          <!-- Chat Input Controls -->
          <div class="chat-input-area">
            <div class="input-row">
              <textarea id="chat-input" placeholder="Connect to the server to start chat sandbox..." disabled></textarea>
              <div class="chat-buttons">
                <button id="btn-clear-chat" class="btn-secondary" title="Clear conversation history" disabled>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                  </svg>
                </button>
                <button id="btn-send" class="btn-primary" disabled>
                  <span>Send</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                  </svg>
                </button>
                <button id="btn-stop" class="btn-danger" style="display: none;">
                  <span>Stop</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="4" width="16" height="16" rx="2" ry="2"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>

        </div><!-- /.chat-window -->

      </div><!-- /.tester-chat-panel -->

      <!-- ── Sidebar Controls (Right - Secondary View) ── -->
      <div class="tester-sidebar">
        
        <!-- Model Settings Card (Consolidated parameter dashboard) -->
        <div class="card parameters-card">
          <h3 class="card-title">Model Settings</h3>

          <div class="panel-body">
            <!-- ── Chat / Inference Settings ── -->
            <!-- System Prompt -->
            <div class="field-group">
              <label for="param-system">System Prompt</label>
              <textarea id="param-system" class="param-textarea" placeholder="Configure the model's behavior...">You are a helpful assistant.</textarea>
            </div>

            <!-- Temperature -->
            <div class="field-group">
              <div class="slider-header">
                <label for="param-temp">Temperature</label>
                <span id="val-temp" class="slider-value">0.7</span>
              </div>
              <input type="range" id="param-temp" min="0.0" max="2.0" step="0.1" value="0.7" class="slider" />
            </div>

            <!-- Context Window -->
            <div class="field-group">
              <div class="slider-header">
                <label for="sidebar-ctx-slider">Context Window</label>
                <span id="sidebar-val-ctx" class="slider-value">2048 tokens</span>
              </div>
              <input type="range" id="sidebar-ctx-slider" min="512" max="16384" step="512" value="2048" class="slider" />
            </div>

            <!-- Flash Attention Checkbox -->
            <div class="field-group checkbox-row">
              <input type="checkbox" id="sidebar-flash" class="styled-checkbox" checked />
              <label for="sidebar-flash" class="checkbox-label">Enable Flash Attention</label>
            </div>

            <!-- Hidden: stream always on, max tokens default -->
            <input type="hidden" id="param-stream" value="true" />
            <input type="hidden" id="param-max-tokens" value="2048" />
          </div>
        </div>

      </div><!-- /.tester-sidebar -->

    </div><!-- /.tester-grid -->

    <!-- ── Developer Diagnostics Logger (Bottom) ── -->
    <div class="diagnostics-section card">
      <button id="btn-toggle-diagnostics" class="diagnostics-trigger">
        <div class="trigger-left">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
          </svg>
          <h3>Developer API Logs</h3>
        </div>
        <span id="diagnostics-toggle-text">Show API Logs</span>
      </button>

      <div id="diagnostics-content" class="diagnostics-content" style="display: none;">
        <div class="logs-grid">
          <div class="log-block">
            <div class="log-block-header">
              <span>HTTP Request Payload</span>
              <button id="btn-copy-req-log" class="btn-mini-copy">Copy</button>
            </div>
            <pre><code id="log-request">Ready for API interactions...</code></pre>
          </div>
          <div class="log-block">
            <div class="log-block-header">
              <span>Server Response Stream / Output Logs</span>
              <button id="btn-copy-res-log" class="btn-mini-copy">Copy</button>
            </div>
            <pre><code id="log-response">Waiting for output...</code></pre>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /.workspace -->

  <!-- ── SEO Guide Section ── -->
  <div class="guide-wrap">
    <article class="seo-guide">
      <h2>Troubleshooting & Local Developer Guide</h2>
      
      <p>LM Studio provides a local model API server conforming to the OpenAI REST specification. When developing browser-based applications that talk to local APIs, security settings and endpoint URLs are the most common points of friction. This guide explains how to properly configure your system.</p>

      <h3>1. Understanding CORS Blocks</h3>
      <p>By default, web browsers block pages loaded from one origin (such as this web page) from making HTTP requests to another origin (like your local machine at <code>http://localhost:1234</code>). This security feature is called Same-Origin Policy. To allow browser-based testing tools to communicate with LM Studio, CORS headers must be added by the server.</p>
      <ul>
        <li><strong>LM Studio GUI:</strong> Click the Developer tab on the left panel, scroll down to <strong>Server Settings</strong>, and switch <strong>"Enable CORS"</strong> to active. This instructs the server to append <code>Access-Control-Allow-Origin: *</code> headers to all responses.</li>
        <li><strong>LM Studio CLI:</strong> If running the server via command line, launch it with the cors argument: <code>lms server start --cors</code>.</li>
      </ul>

      <h3>2. Model Loading vs. OpenAI Compatibility</h3>
      <p>LM Studio features two layers of API endpoints:</p>
      <ul>
        <li><strong>OpenAI-Compatible Endpoint (<code>/v1</code>):</strong> Supports standard routes like <code>/v1/chat/completions</code> and <code>/v1/models</code>. This is great for plugging LM Studio into existing code written for OpenAI. However, it requires a model to be pre-loaded in the LM Studio GUI before requests will succeed.</li>
        <li><strong>Native Endpoint (<code>/api/v1</code>):</strong> Provides granular controller access. Using the native endpoints, this tool can check which models are currently loaded, request specific models to load with defined context sizes, and unload them to free up GPU memory.</li>
      </ul>

      <h3>3. GPU VRAM Allocation during Model Loading</h3>
      <p>When loading a model via <code>POST /api/v1/models/load</code>, the configurations specified in the payload affect how much GPU memory is claimed:</p>
      <ul>
        <li><strong>Context Length:</strong> A larger context window creates a larger KV cache, which scales linearly with the sequence length. If you experience Out-Of-Memory (OOM) failures when loading, try reducing the context length value (e.g., from 8192 to 2048).</li>
        <li><strong>Flash Attention:</strong> Speeds up attention calculations and reduces the cache's VRAM footprint. Toggle this on if your GPU engine supports it.</li>
      </ul>
    </article>
  </div>
</Layout>

<!-- Scoped Styles -->
<style>
  /* ── Hero ── */
  .tool-hero {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 64px 24px 56px;
    text-align: center;
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 14px;
  }

  .tool-title {
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-primary);
    margin-bottom: 14px;
  }

  .accent {
    font-style: italic;
    color: var(--color-tertiary);
  }

  .tool-desc {
    font-size: 1rem;
    color: var(--color-secondary);
    margin: 0;
  }

  /* ── Workspace ── */
  .workspace {
    max-width: 1160px;
    margin: 0 auto;
    padding: 40px 24px 64px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── Tester Grid (Chat Left, Settings Right) ── */
  .tester-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 24px;
    align-items: start;
  }

  .tester-sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Inline Badge Label Row ── */
  .label-row-inline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    min-height: 24px;
  }

  .label-row-inline label {
    margin: 0;
  }



  /* ── Alert Box (CORS) inside messages container ── */
  .alert-box {
    border-radius: var(--rounded-md);
    padding: 12px 14px;
    font-size: 0.8rem;
  }

  .error-alert {
    background: rgba(228, 23, 73, 0.04);
    border: 1px solid rgba(228, 23, 73, 0.2);
    color: var(--color-primary);
  }

  .alert-header {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-error);
    margin-bottom: 6px;
    font-weight: 700;
  }

  .alert-header svg {
    flex-shrink: 0;
  }

  .alert-desc {
    color: var(--color-secondary);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .alert-steps ol {
    padding-left: 18px;
    margin-bottom: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .alert-steps li {
    color: var(--color-secondary);
    line-height: 1.4;
  }

  .badge-inline-green {
    background: var(--color-success);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 1px 5px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .alert-cli-note {
    background: rgba(28, 43, 51, 0.06);
    border-radius: var(--rounded-sm);
    padding: 6px 10px;
    font-family: 'Courier New', monospace;
    font-size: 0.76rem;
    color: var(--color-primary);
    text-align: center;
  }

  /* ── Chat Model Searchable Combobox Dropdown ── */
  .model-select-wrapper {
    position: relative;
    width: 250px; /* Compact width for header bar */
    max-width: 100%;
    flex-shrink: 1;
    min-width: 120px;
  }

  .model-select-wrapper .custom-select-container {
    border-radius: var(--rounded-sm);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    overflow: visible !important;
    height: 32px;
  }

  .model-select-wrapper input.custom-select-search-input {
    padding: 6px 36px 6px 10px !important;
    font-size: 0.82rem;
    font-weight: 600;
    height: 30px;
    cursor: pointer;
  }

  .model-select-wrapper .custom-select-arrow {
    width: 32px;
    height: 30px;
    cursor: pointer;
  }

  .model-select-wrapper .custom-select-dropdown {
    top: 100%;
    margin-top: 4px;
    box-shadow: 0 4px 18px rgba(28, 43, 51, 0.12);
    width: 100%;
  }

  .btn-mini-unload {
    font-size: 0.76rem;
    padding: 5px 12px;
    border-radius: var(--rounded-sm);
    height: 32px;
    display: inline-flex;
    align-items: center;
  }

  .section-desc {
    font-size: 0.82rem;
    color: var(--color-secondary);
  }

  /* ── Parameters Card ── */
  .parameters-card {
    /* inherits .card from global */
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 18px;
  }

  .panel-body {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .settings-divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2px 0;
  }

  /* Slider — VRAM calculator style */
  .slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .slider-value {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-tertiary);
  }

  .param-textarea {
    height: 72px;
    font-family: var(--font-family);
    font-size: 0.88rem;
    line-height: 1.4;
    resize: none;
  }

  .label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Plain checkbox row — no pill container */
  .checkbox-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
  }

  /* Custom styled checkbox */
  .styled-checkbox {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    min-width: 16px;
    border: 1.5px solid #cbd5e1;
    border-radius: 4px;
    outline: none;
    cursor: pointer;
    background-color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .styled-checkbox:checked {
    background-color: var(--color-tertiary);
    border-color: var(--color-tertiary);
  }

  .styled-checkbox:checked::after {
    content: "";
    display: block;
    width: 4px;
    height: 8px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg) translate(-0.5px, -1px);
    position: absolute;
  }

  .styled-checkbox:hover:not(:checked) {
    border-color: var(--color-tertiary);
  }

  .styled-checkbox:focus-visible {
    box-shadow: 0 0 0 2px rgba(8, 102, 255, 0.2);
  }

  .checkbox-label {
    margin: 0;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.875rem;
    cursor: pointer;
    color: var(--color-primary);
    line-height: 1.4;
  }

  /* Slider — clean track, no border */
  .slider {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: rgba(28, 43, 51, 0.08);
    outline: none;
    margin: 8px 0 4px;
    padding: 0 !important;
    border: none !important;
  }

  .slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-tertiary);
    cursor: pointer;
    transition: transform 0.1s;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
  }

  .slider::-webkit-slider-thumb:hover {
    transform: scale(1.2);
  }

  /* ── Chat Panel (Left) ── */
  .tester-chat-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    display: flex;
    flex-direction: column;
    height: 520px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(28, 43, 51, 0.04);
  }

  /* Chat Header Restructured */
  .active-model-bar {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: nowrap; /* Keep exactly in one row */
    overflow: visible !important; /* Ensure absolute dropdown lists do not get clipped */
    height: 52px;
  }

  .header-server-settings {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: nowrap;
    flex-shrink: 0;
  }

  .header-model-settings {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: nowrap;
    flex-shrink: 1;
    min-width: 0;
    overflow: visible !important;
  }

  .active-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .header-url-input {
    width: 160px;
    padding: 5px 8px !important;
    font-size: 0.82rem !important;
    height: 32px;
  }

  .btn-mini-connect {
    padding: 5px 12px !important;
    font-size: 0.8rem !important;
    height: 32px;
  }

  /* Chat window & visual separation container */
  .chat-window {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    position: relative;
    min-height: 0;
  }

  /* Visual separation viewport with top gap spacing */
  .chat-messages-container {
    flex-grow: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    background-color: #FAFBFD;
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    margin: 16px 20px 20px;
    box-shadow: inset 0 2px 6px rgba(28, 43, 51, 0.04);
    position: relative;
  }

  .chat-welcome-state {
    margin: auto;
    text-align: center;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    color: var(--color-secondary);
    padding: 24px;
  }

  .chat-welcome-state svg {
    color: rgba(28, 43, 51, 0.2);
  }

  .chat-welcome-state h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
  }

  .chat-welcome-state p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  /* Message Bubbles */
  .chat-messages-container :global(.chat-msg) {
    display: flex;
    flex-direction: column;
    max-width: 75%;
    animation: fadeIn 0.15s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .chat-messages-container :global(.chat-msg.user) {
    align-self: flex-end;
  }

