---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogType?: string;
}

const { 
  title, 
  description, 
  canonicalURL = Astro.url.href, 
  ogType = 'website' 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />

  <!-- Fonts: Inter + Fraunces -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,700;1,9..144,800;1,9..144,900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <meta name="generator" content={Astro.generator} />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo" aria-label="AsapGuide Tools home">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        <span class="logo-name">AsapGuide Tools</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="/" class="nav-link">All Tools</a>
        <a href="https://youtube.com/@asapguide" target="_blank" rel="noopener noreferrer" class="nav-cta">YouTube ↗</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">© {new Date().getFullYear()} AsapGuide Tools</p>
      <div class="footer-links">
        <a href="https://youtube.com/@asapguide" target="_blank" rel="noopener noreferrer">YouTube</a>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ── Header ── */
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    height: 64px;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .logo {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo svg { color: var(--color-tertiary); flex-shrink: 0; }

  .logo-name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .nav {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--color-primary); }

  .nav-cta {
    text-decoration: none;
    background: var(--color-tertiary);
    color: #fff;
    font-weight: 600;
    font-size: 0.88rem;
    padding: 7px 14px;
    border-radius: var(--rounded-md);
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .nav-cta:hover { opacity: 0.88; }

  main { min-height: calc(100vh - 64px - 60px); }

  /* ── Footer ── */
  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 18px var(--spacing-md);
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .footer-copy {
    font-size: 0.82rem;
    color: var(--color-secondary);
    margin: 0;
    white-space: nowrap;
  }

  .footer-links {
    display: flex;
    flex-shrink: 0;
    gap: 20px;
  }

  .footer-links a {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-secondary);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--color-primary); }

  @media (max-width: 640px) {
    .footer-inner { flex-wrap: wrap; }
    .nav-link { display: none; }
    .nav { gap: 12px; }
  }

  @media (max-width: 360px) {
    .header-inner { flex-wrap: wrap; height: auto; padding: 12px var(--spacing-md); justify-content: center; }
    .nav { justify-content: center; }
  }
</style>
